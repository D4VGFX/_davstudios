---
import '../../styles/global.css';
import '../../styles/projects.css';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <script is:inline src="https://app.termly.io/resource-blocker/bc13f957-c21f-4ed9-ba27-fc67ff4d7baa?autoBlock=on"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta property="article:modified_time" content="2026-03-10T09:30:00+01:00" />
    <meta property="article:published_time" content="2026-03-10T09:35:00+01:00" />

    <!-- SEO primari -->
    <title>Progetti | _davstudios</title>
    <meta name="description" content="Scopri i progetti di _davstudios: identità visive, siti web e brand digitali realizzati con cura e precisione.">
    <meta name="author" content="David Spano">
    <meta name="robots" content="index, follow">
    <meta name="language" content="it">
    <link rel="canonical" href="https://davstudios.it/progetti/">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://davstudios.it/progetti/">
    <meta property="og:title" content="Progetti | _davstudios">
    <meta property="og:description" content="Scopri i progetti di _davstudios: identità visive, siti web e brand digitali realizzati con cura e precisione.">
    <meta property="og:image" content="https://davstudios.it/assets/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="_davstudios">
    <meta property="og:locale" content="it_IT">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Progetti | _davstudios">
    <meta name="twitter:description" content="Scopri i progetti di _davstudios: identità visive, siti web e brand digitali realizzati con cura e precisione.">
    <meta name="twitter:image" content="https://davstudios.it/assets/og-image.jpg">

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="theme-color" content="#0071E3">

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,300&display=swap" rel="stylesheet">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Progetti | _davstudios",
  "url": "https://davstudios.it/progetti/",
  "description": "Scopri i progetti di _davstudios: identità visive, siti web e brand digitali realizzati con cura e precisione.",
  "author": { "@type": "Person", "name": "David Spano" }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://davstudios.it/" },
    { "@type": "ListItem", "position": 2, "name": "Progetti", "item": "https://davstudios.it/progetti/" }
  ]
}
</script>
</head>
<body>

<div id="cursor-preview">
  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#AEAEB2" stroke-width="1.2">
    <rect x="3" y="3" width="18" height="18" rx="3"/>
    <circle cx="8.5" cy="8.5" r="1.5"/>
    <path d="M21 15l-5-5L5 21"/>
  </svg>
</div>

    
    <nav class="navbar">
        <div class="nav-section nav-left">
            <a href="/chi-sono">CHI SONO</a>
            <a href="#" class="nav-active">PROGETTI</a>
        </div>
        <div class="nav-logo">
            <a href="/">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="nav-logo-img"/>
            </a>
        </div>
        <div class="nav-section nav-right">
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
    </nav>
    <div class="nav-drawer" id="nav-drawer">
        <div class="nav-drawer__inner">
            <a href="/chi-sono">CHI SONO</a>
            <a href="#" class="nav-active">PROGETTI</a>
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
    </div>
    <div class="nav-overlay" id="nav-overlay"></div>

<div class="page-header">
  <div>
    <p class="header-label" style="animation:fadeUp .6s .05s var(--ease) both">Il mio lavoro</p>
    <h1 class="header-title" style="animation:fadeUp .75s .12s var(--ease) both">Progetti</h1>
    <p class="header-sub" style="animation:fadeUp .75s .22s var(--ease) both">Graphic design, identità visive e sviluppo web —<br>ogni progetto racconta una storia.</p>
  </div>
  <div class="filter-wrap" style="animation:fadeUp .75s .32s var(--ease) both">
    <div class="filter-bar">
      <button class="f-btn active" data-filter="all">
        Tutti <span class="f-badge" id="b-all">0</span>
      </button>
      <button class="f-btn" data-filter="graphic">
        Graphic Design <span class="f-badge" id="b-graphic">0</span>
      </button>
      <button class="f-btn" data-filter="web">
        Web Development <span class="f-badge" id="b-web">0</span>
      </button>
    </div>
  </div>
</div>

<div class="project-list" id="project-list">

  <div class="p-row p-row--anim"
  data-img="/assets/graphic_design/Pannelli.jpg"
  style="--row-delay:0.45s"
  data-category="graphic"
  data-title="Pannelli Promozionali — Gastronomia Sabatelli"
  data-role="Graphic Design · Visual Communication"
  data-year="2025"
  data-tags="Graphic Design,Print,Illustrazione,Food,Branding"
  data-desc="Serie di tre pannelli grafici realizzati per Gastronomia Sabatelli, negozio alimentare di Fasano (BR). Ogni pannello valorizza una categoria di prodotti — salumi, formaggi e gastronomia — con un visual d'impatto pensato per l'esposizione in punto vendita."
  data-link="#">
    <span class="p-num"></span>
    <span class="p-title">Pannelli Promozionali — Gastronomia Sabatelli</span>
    <span class="p-cat">Graphic Design</span>
    <span class="p-year">2025</span>
    <span class="p-arrow">→</span>
  </div>

  <div class="p-row p-row--anim"
  data-img="/assets/web_development/Alex_Natola.jpg"
  style="--row-delay:0.50s"
  data-category="web"
  data-title="Sito Web — Alex Natola"
  data-role="Web Design · Frontend Development"
  data-year="2026"
  data-tags="Web Design,HTML,CSS,Musica,Personal Branding"
  data-desc="Sito ufficiale per il cantautore pugliese Alex Natola. Progettato per raccontare la sua identità artistica, con sezioni dedicate a biografia, discografia e contatti. Prima versione realizzata nel 2024, versione definitiva pubblicata nel marzo 2026."
  data-link="#">
    <span class="p-num"></span>
    <span class="p-title">Sito Web — Alex Natola</span>
    <span class="p-cat">Web Development</span>
    <span class="p-year">2026</span>
    <span class="p-arrow">→</span>
  </div>

  <div class="p-row p-row--anim"
  data-img="/assets/graphic_design/Etichette_DeoPlus.jpg"
  style="--row-delay:0.55s"
  data-category="graphic"
  data-title="Etichette Prodotto — Lindarella DeoPlus"
  data-role="Graphic Design · Packaging Design"
  data-year="2025"
  data-tags="Packaging,Label Design,Print,Branding,Prodotto"
  data-desc="Progettazione delle etichette per la linea DeoPlus di Lindarella Parfum, profumatori per tessuti e ambienti distribuiti da Kemix Industriale S.R.L. (Pomezia). Un progetto che segna l'inizio di una collaborazione continuativa con l'azienda, con altri lavori già completati e nuovi in corso."
  data-link="#">
    <span class="p-num"></span>
    <span class="p-title">Etichette Prodotto — Lindarella DeoPlus</span>
    <span class="p-cat">Graphic Design</span>
    <span class="p-year">2025</span>
    <span class="p-arrow">→</span>
  </div>

</div>

<div id="no-results">Nessun progetto in questa categoria.</div>

<div id="backdrop"></div>

<div id="panel">
  <div id="panel-img">
    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="#AEAEB2" stroke-width="1">
      <rect x="3" y="3" width="18" height="18" rx="3"/>
      <circle cx="8.5" cy="8.5" r="1.5"/>
      <path d="M21 15l-5-5L5 21"/>
    </svg>
  </div>
  <div class="panel-body">
    <span class="panel-cat"   id="panel-cat"></span>
    <h2   class="panel-title" id="panel-title"></h2>
    <div class="panel-meta">
      <div><span class="meta-label">Ruolo</span><span class="meta-val" id="panel-role"></span></div>
      <div><span class="meta-label">Anno</span><span  class="meta-val" id="panel-year"></span></div>
    </div>
    <p  class="panel-desc"  id="panel-desc"></p>
    <div class="panel-tags" id="panel-tags"></div>
    <a  class="panel-link"  id="panel-link" href="#" target="_blank" rel="noopener">
      Visita il progetto
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    </a>
    <div class="panel-nav">
      <button class="nav-btn" id="btn-prev">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <span class="nav-ctr" id="nav-ctr"></span>
      <button class="nav-btn" id="btn-next">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
  <button id="btn-close">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>
</div>

    
    <footer class="main-footer">
        <div class="footer-logo">
            <a href="/">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="footer-logo-img"/>
            </a>
        </div>
        <nav class="footer-nav">
            <a href="/chi-sono" >CHI SONO</a>
            <a href="#" class="nav-active">PROGETTI</a>
            <a href="/processo" >PROCESSO</a>
            <a href="/contattami" >CONTATTAMI</a>
            <a href="/privacy-policy" >PRIVACY</a>
            <a href="/cookie-policy" >COOKIE</a>
        </nav>
        <div class="footer-copyright">
            <p>© 2026 <a href="https://www.instagram.com/_davstudios/" style="color:var(--ink);text-decoration:none">_davstudios</a> — Tutti i diritti riservati</p>
        </div>
    </footer>

    <script>import '../../scripts/global.js';</script>
    <script>import '../../scripts/projects.js';</script>

</body>
</html>