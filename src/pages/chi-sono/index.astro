---
import '../../styles/global.css';
import '../../styles/about.css';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <script is:inline src="https://app.termly.io/resource-blocker/bc13f957-c21f-4ed9-ba27-fc67ff4d7baa?autoBlock=on"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta property="article:modified_time" content="2026-03-10T09:30:00+01:00" />
    <meta property="article:published_time" content="2026-03-10T09:35:00+01:00" />

    <!-- SEO primari -->
    <title>Chi Sono | _davstudios</title>
    <meta name="description" content="Sono David Spano, designer e sviluppatore web freelance. Creo esperienze digitali su misura per brand che vogliono lasciare il segno.">
    <meta name="author" content="David Spano">
    <meta name="robots" content="index, follow">
    <meta name="language" content="it">
    <link rel="canonical" href="https://davstudios.it/chi-sono/">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://davstudios.it/chi-sono/">
    <meta property="og:title" content="Chi Sono | _davstudios">
    <meta property="og:description" content="Sono David Spano, designer e sviluppatore web freelance. Creo esperienze digitali su misura per brand che vogliono lasciare il segno.">
    <meta property="og:image" content="https://davstudios.it/assets/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="_davstudios">
    <meta property="og:locale" content="it_IT">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Chi Sono | _davstudios">
    <meta name="twitter:description" content="Sono David Spano, designer e sviluppatore web freelance. Creo esperienze digitali su misura per brand che vogliono lasciare il segno.">
    <meta name="twitter:image" content="https://davstudios.it/assets/og-image.jpg">

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="theme-color" content="#0071E3">

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,300&display=swap" rel="stylesheet">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "David Spano",
  "url": "https://davstudios.it/chi-sono/",
  "jobTitle": "Web Designer & Developer",
  "description": "Designer e sviluppatore web freelance con sede in provincia di Brindisi. Creo identità digitali su misura per brand che vogliono lasciare il segno.",
  "image": "https://davstudios.it/assets/og-image.jpg",
  "email": "info@davstudios.it",
  "address": { "@type": "PostalAddress", "addressLocality": "Brindisi", "addressRegion": "Puglia", "addressCountry": "IT" },
  "knowsAbout": ["Web Design", "Brand Identity", "Sviluppo Web", "UI/UX Design", "Graphic Design", "Astro", "HTML", "CSS", "JavaScript"],
  "worksFor": { "@type": "Organization", "name": "_davstudios", "url": "https://davstudios.it" },
  "sameAs": [
    "https://www.instagram.com/_davstudios",
    "https://www.facebook.com/the.davstudios"
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "David Spano",
    "jobTitle": "Web Designer & Developer",
    "worksFor": { "@type": "Organization", "name": "_davstudios" },
    "knowsAbout": ["Web Design", "Brand Identity", "Sviluppo Web", "UI/UX Design", "Graphic Design"],
    "sameAs": [
      "https://www.instagram.com/_davstudios",
      "https://www.facebook.com/the.davstudios"
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://davstudios.it/" },
    { "@type": "ListItem", "position": 2, "name": "Chi Sono", "item": "https://davstudios.it/chi-sono/" }
  ]
}
</script>
</head>
<body>

    
    <nav class="navbar">
        <div class="nav-section nav-left">
            <a href="#" class="nav-active">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
        </div>
        <div class="nav-logo">
            <a href="/">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="nav-logo-img"/>
            </a>
        </div>
        <div class="nav-section nav-right">
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
    </nav>
    <div class="nav-drawer" id="nav-drawer">
        <div class="nav-drawer__inner">
            <a href="#" class="nav-active">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
    </div>
    <div class="nav-overlay" id="nav-overlay"></div>

    
    <section class="about-hero">
        <div class="about-hero__text">
            <p class="about-hero__label reveal">Chi sono</p>
            <h1 class="about-hero__name" style="animation:fadeUp .75s .12s var(--ease) both">
                David<br><span>Spano</span>
            </h1>
            <p class="about-hero__role reveal delay-2">
                Designer · Sviluppatore · Creatore
            </p>
            <p class="about-hero__intro reveal delay-3">
                La mia missione in <b>_davstudios</b> è dare una forma concreta
                alla tua visione attraverso un <b>design audace</b> e una solida
                base tecnologica. Come <b>creatore digitale</b>, mi impegno a
                costruire <b>identità forti</b> e piattaforme web capaci di
                adattarsi alle sfide di un mercato in continua evoluzione.
                Non mi occupo solo di grafica, ma di progettare strumenti che
                comunichino il tuo valore e garantiscano una <b>presenza online</b>
                solida, scalabile e di successo.
            </p>
            <div class="about-hero__cta reveal delay-3">
                <a href="/progetti" class="btn-oval">Vedi i miei progetti</a>
                <a href="#storia" class="about-scroll-hint">
                    Scopri di più
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 5v14M5 12l7 7 7-7"/>
                    </svg>
                </a>
            </div>
        </div>

        
        <div class="about-hero__photo reveal delay-2">
            
            <img src="/assets/foto-profilo.jpg" alt="David Spano" class="about-photo-img"/>
            
            <div class="photo-ring photo-ring--1"></div>
            <div class="photo-ring photo-ring--2"></div>
            <div class="photo-dot photo-dot--1"></div>
            <div class="photo-dot photo-dot--2"></div>
            <div class="photo-dot photo-dot--3"></div>
        </div>
    </section>

    
    <section class="stats-strip">
        <div class="stats-strip__inner">
            <div class="stat-item reveal">
                <span class="stat-number count-up" data-count="47" data-suffix="+">0</span>
                <span class="stat-label">Progetti completati</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item reveal delay-1">
                <span class="stat-number count-up" data-count="5" data-suffix=" anni">0</span>
                <span class="stat-label">Di esperienza</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item reveal delay-2">
                <span class="stat-number count-up" data-count="99" data-suffix="%">0</span>
                <span class="stat-label">Clienti soddisfatti</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item reveal delay-3">
                <span class="stat-number count-up" data-count="6">0</span>
                <span class="stat-label">Attestati ICDL</span>
            </div>
        </div>
    </section>

    
    <section class="story-section" id="storia">
        <div class="story-section__inner">

            
            <aside class="story-timeline">
                <div class="timeline-line"></div>
                <div class="timeline-node" data-year="2019">
                    <div class="tnode-dot"></div>
                    <div class="tnode-card reveal">
                        <span class="tnode-year">2019</span>
                        <p class="tnode-text">Inizio il mio viaggio nel <b>design</b>, focalizzandomi sullo studio delle interfacce e della tipografia.</p>
                    </div>
                </div>
                <div class="timeline-node" data-year="2021">
                    <div class="tnode-dot"></div>
                    <div class="tnode-card reveal delay-1">
                        <span class="tnode-year">2021</span>
                        <p class="tnode-text">Amplio i miei orizzonti verso lo <b>sviluppo front-end</b>, imparando a trasformare i layout in siti web interattivi.</p>
                    </div>
                </div>
                <div class="timeline-node" data-year="2023">
                    <div class="tnode-dot"></div>
                    <div class="tnode-card reveal delay-2">
                        <span class="tnode-year">2023</span>
                        <p class="tnode-text">Nasce <b>_davstudios</b>, il mio studio creativo dedicato a soluzioni digitali per professionisti e aziende.</p>
                    </div>
                </div>
                <div class="timeline-node" data-year="oggi">
                    <div class="tnode-dot tnode-dot--active"></div>
                    <div class="tnode-card reveal delay-3">
                        <span class="tnode-year" style="color:var(--accent)">Oggi</span>
                        <p class="tnode-text">Continuo a progettare <b>esperienze utente</b> d'avanguardia, unendo estetica raffinata e tecnologie moderne.</p>
                    </div>
                </div>
            </aside>

            
            <div class="story-body">
                <p class="section-label reveal">La mia storia</p>
                <h2 class="section-title reveal delay-1">
                    Da dove vengo,<br>dove sto andando.
                </h2>
                <div class="story-paragraphs">
                    <p class="reveal delay-2">
                        Il mio percorso nel mondo digitale è guidato da una costante curiosità e
                        dalla ricerca della perfezione tecnica. Ho iniziato esplorando le basi del
                        <b>graphic design</b>, per poi evolvere verso lo <b>sviluppo web</b> con
                        l'obiettivo di dare vita a progetti completi e indipendenti.
                        Ogni tappa della mia storia rappresenta una sfida vinta e una nuova competenza
                        acquisita, permettendomi oggi di offrire una visione a 360° sulla creazione
                        di un <b>brand</b>.
                    </p>
                    <p class="reveal delay-3">
                        Dalle prime sperimentazioni creative fino alla fondazione
                        di <b>_davstudios</b>, ho sempre messo al centro la qualità del codice e l'impatto visivo,
                        convinto che un'ottima <b>presenza online</b> sia il risultato di un'evoluzione
                        continua e di una profonda passione per l'<b>innovazione digitale</b>.
                    </p>
                </div>
            </div>

        </div>
    </section>

    
    <section class="values-section">
        <div class="values-section__inner">
            <p class="section-label reveal" style="text-align:center">I miei valori</p>
            <h2 class="section-title reveal delay-1" style="text-align:center">
                Cosa guida ogni<br>mia scelta.
            </h2>

            <div class="values-grid">

                <div class="value-card reveal">
                    <div class="value-card__icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <h3 class="value-card__title">Qualità</h3>
                    <p class="value-card__text">
                        Non accetto compromessi quando si tratta di <b>eccellenza visiva</b>
                        e tecnica. Ogni pixel e ogni riga di codice sono curati per garantire
                        un <b>prodotto finale</b> di livello superiore, capace di durare nel
                        tempo e rappresentare al meglio il valore del tuo <b>brand</b>.
                    </p>
                </div>

                <div class="value-card reveal delay-1">
                    <div class="value-card__icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 6v6l4 2"/>
                        </svg>
                    </div>
                    <h3 class="value-card__title">Velocità</h3>
                    <p class="value-card__text">
                        In un mondo digitale rapido, la <b>reattività</b> è tutto. Ottimizzo
                        ogni piattaforma per garantire <b>prestazioni elevate</b> e tempi di
                        caricamento minimi, assicurando un'esperienza fluida che rispetta il
                        tempo dei tuoi utenti e migliora il tuo <b>posizionamento online</b>.
                    </p>
                </div>

                <div class="value-card reveal delay-2">
                    <div class="value-card__icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <h3 class="value-card__title">Empatia</h3>
                    <p class="value-card__text">
                        Metto le persone al centro di ogni <b>scelta progettuale</b>. Ascoltare
                        le tue necessità mi permette di creare <b>soluzioni umane</b> e intuitive,
                        costruendo un rapporto di fiducia che trasforma una semplice fornitura
                        in una vera <b>partnership creativa</b>.
                    </p>
                </div>

            </div>
        </div>
    </section>

    
    <section class="skills-section">
        <div class="skills-section__inner">

            <div class="skills-text">
                <p class="section-label reveal">Le mie competenze</p>
                <h2 class="section-title reveal delay-1">
                    Strumenti e<br>linguaggi che uso.
                </h2>
                <p class="skills-desc reveal delay-2">
                    Il mio approccio al lavoro si basa su un set di <b>competenze tecniche</b>
                    multidisciplinari che mi permettono di gestire un progetto dalla strategia
                    al lancio. Utilizzo i migliori <b>strumenti di design</b> per creare
                    interfacce moderne e intuitive, che vengono poi tradotte in codice attraverso
                    uno <b>sviluppo frontend</b> pulito, veloce e accessibile. La combinazione di
                    competenze in <b>branding</b> e <b>motion design</b> mi consente di dare vita
                    a narrazioni digitali coerenti, assicurando che ogni <b>strategia digitale</b>
                    sia supportata da una realizzazione tecnica solida e all'avanguardia.
                </p>
            </div>

            <div class="skills-bars">
                <div class="skill-bar reveal">
                    <div class="skill-bar__header">
                        <span class="skill-bar__name">Design UI/UX</span>
                        <span class="skill-bar__pct">95%</span>
                    </div>
                    <div class="skill-bar__track">
                        <div class="skill-bar__fill" data-width="95"></div>
                    </div>
                </div>
                <div class="skill-bar reveal delay-1">
                    <div class="skill-bar__header">
                        <span class="skill-bar__name">Sviluppo Frontend</span>
                        <span class="skill-bar__pct">88%</span>
                    </div>
                    <div class="skill-bar__track">
                        <div class="skill-bar__fill" data-width="88"></div>
                    </div>
                </div>
                <div class="skill-bar reveal delay-2">
                    <div class="skill-bar__header">
                        <span class="skill-bar__name">Branding</span>
                        <span class="skill-bar__pct">92%</span>
                    </div>
                    <div class="skill-bar__track">
                        <div class="skill-bar__fill" data-width="92"></div>
                    </div>
                </div>
                <div class="skill-bar reveal delay-3">
                    <div class="skill-bar__header">
                        <span class="skill-bar__name">Motion Design</span>
                        <span class="skill-bar__pct">75%</span>
                    </div>
                    <div class="skill-bar__track">
                        <div class="skill-bar__fill" data-width="75"></div>
                    </div>
                </div>
                <div class="skill-bar reveal delay-3">
                    <div class="skill-bar__header">
                        <span class="skill-bar__name">Strategia Digitale</span>
                        <span class="skill-bar__pct">83%</span>
                    </div>
                    <div class="skill-bar__track">
                        <div class="skill-bar__fill" data-width="83"></div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    
    <section class="quote-section">
        <div class="quote-section__inner reveal">
            <svg class="quote-mark" viewBox="0 0 60 48" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
                <path d="M0 48V29.538C0 12.923 9.231 3.692 27.692 0L30.462 4.615C22.154 6.769
                         17.077 11.385 15.231 18.462H24V48H0ZM36 48V29.538C36 12.923 45.231 3.692
                         63.692 0L66.462 4.615C58.154 6.769 53.077 11.385 51.231 18.462H60V48H36Z"
                      fill="currentColor" opacity=".15"/>
            </svg>
            <blockquote class="quote-text">
                La mia <b>arte</b> incontra la tua <b>visione</b>: attraverso una
                <b>comunicazione essenziale</b>, trasformo la necessità del prodotto
                in un <b>design d'impatto</b> e indimenticabile, perfettamente
                allineato ai tuoi <b>obiettivi</b>.
            </blockquote>
            <cite class="quote-author">— David, 2024</cite>
        </div>
    </section>

    
    <section class="about-cta">
        <div class="about-cta__inner reveal">
            <h2 class="about-cta__title">Lavoriamo insieme?</h2>
            <p class="about-cta__sub">
                Racconta il tuo progetto — rispondo entro 24 ore.
            </p>
            <a href="/contattami" class="btn-oval">Scrivimi ora</a>
        </div>
    </section>

    
    <footer class="main-footer">
        <div class="footer-logo">
            <a href="/">
				<img src="/assets/_davstudios.svg" alt="Il tuo nome" class="footer-logo-img"/>
			</a>
        </div>
        <nav class="footer-nav">
            <a href="#" class="nav-active">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
            <a href="/processo">PROCESSO</a>
            <a href="/contattami">CONTATTAMI</a>
            <a href="/privacy-policy">PRIVACY</a>
            <a href="/cookie-policy">COOKIE</a>
        </nav>
        <div class="footer-copyright">
            <p>© 2026 <a href="https://www.instagram.com/_davstudios/" style="color: var(--ink); text-decoration: none">_davstudios</a> — Tutti i diritti riservati</p>
        </div>
    </footer>

    <script>import '../../scripts/global.js'</script>
    <script>import '../../scripts/about.js'</script>

</body>
</html>