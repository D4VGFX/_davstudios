  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Ascolto", "text": "Ascolto la tua visione e definisco gli obiettivi del progetto." },
    { "@type": "HowToStep", "position": 2, "name": "Strategia", "text": "Definisco una strategia mirata per il tuo brand e il tuo mercato." },
    { "@type": "HowToStep", "position": 3, "name": "Design", "text": "Progetto l'identità visiva e l'esperienza utente su misura." },
    { "@type": "HowToStep", "position": 4, "name": "Sviluppo", "text": "Sviluppo il sito web con tecnologie moderne e performanti." },
    { "@type": "HowToStep", "position": 5, "name": "Revisione", "text": "Revisione minuziosa per un'esperienza utente impeccabile." },
    { "@type": "HowToStep", "position": 6, "name": "Lancio", "text": "Lancio il prodotto finale con precisione e impatto sul mercato." }
  ]
}
</script>

