---
import '../../styles/global.css';
import '../../styles/legal.css';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <title>Privacy Policy | _davstudios</title>
    <meta name="robots" content="noindex, follow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,300&display=swap" rel="stylesheet">
</head>
<body>

    
    <nav class="navbar">
        <div class="nav-section nav-left">
            <a href="/chi-sono">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
        </div>
        <div class="nav-logo">
            <a href="/">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="nav-logo-img"/>
            </a>
        </div>
        <div class="nav-section nav-right">
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
    </nav>
    <div class="nav-drawer" id="nav-drawer">
        <div class="nav-drawer__inner">
            <a href="/chi-sono">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
    </div>
    <div class="nav-overlay" id="nav-overlay"></div>

    
    <div class="reading-bar" aria-hidden="true">
        <div class="reading-bar__fill" id="reading-fill"></div>
    </div>

    
    <header class="legal-hero">
        <div class="legal-hero__inner">
            <div>
                <span class="legal-hero__label" style="animation:fadeUp .6s .05s var(--ease) both">
                    Documento legale
                </span>
                <h1 class="legal-hero__title" style="animation:fadeUp .75s .12s var(--ease) both">
                    Privacy<br>
                    <span class="legal-hero__em">Policy.</span>
                </h1>
                <p class="legal-hero__sub" style="animation:fadeUp .75s .22s var(--ease) both">
                    Come raccogliamo, utilizziamo e proteggiamo
                    i tuoi dati personali, in conformità al
                    Regolamento UE 2016/679 (GDPR).
                </p>
            </div>
            <div class="legal-meta" style="animation:fadeUp .75s .3s var(--ease) both">
                <div class="legal-meta__item">
                    <span class="legal-meta__key">Versione</span>
                    <span class="legal-meta__val">1.0</span>
                </div>
                <div class="legal-meta__item">
                    <span class="legal-meta__key">Ultimo aggiornamento</span>
                    <span class="legal-meta__val">Marzo 2026</span>
                </div>
                <div class="legal-meta__item">
                    <span class="legal-meta__key">Normativa</span>
                    <span class="legal-meta__val">GDPR UE 2016/679</span>
                </div>
            </div>
        </div>
    </header>

    
    <div class="legal-layout">

        
        <nav class="legal-toc" aria-label="Indice">
            <p class="legal-toc__title">Indice</p>
            <a href="#titolare" class="toc-link">
                <span class="toc-num">01</span> Titolare del trattamento
            </a>
            <a href="#dati-raccolti" class="toc-link">
                <span class="toc-num">02</span> Dati raccolti
            </a>
            <a href="#finalita" class="toc-link">
                <span class="toc-num">03</span> Finalità e base giuridica
            </a>
            <a href="#conservazione" class="toc-link">
                <span class="toc-num">04</span> Conservazione
            </a>
            <a href="#condivisione" class="toc-link">
                <span class="toc-num">05</span> Condivisione dati
            </a>
            <a href="#diritti" class="toc-link">
                <span class="toc-num">06</span> I tuoi diritti
            </a>
            <a href="#minori" class="toc-link">
                <span class="toc-num">07</span> Minori
            </a>
            <a href="#modifiche" class="toc-link">
                <span class="toc-num">08</span> Modifiche
            </a>
            <a href="#contatti-privacy" class="toc-link">
                <span class="toc-num">09</span> Contatti
            </a>
        </nav>

        
        <article class="legal-content">

            
            <section class="legal-section reveal" id="titolare">
                <span class="legal-section__num">01</span>
                <h2 class="legal-section__title">Titolare del trattamento</h2>
                <p>
                    Il Titolare del trattamento dei dati personali raccolti tramite
                    il sito <strong>_davstudios</strong> (di seguito "Sito") è:
                </p>
                <div class="legal-contact-box">
                    <div class="lcb-item">
                        <span class="lcb-label">Nome / Ragione sociale</span>
                        <span class="lcb-val">David Spano<br><em style="font-weight:300;font-size:13px;color:var(--xsoft)">_davstudios</em></span>
                    </div>
                    <div class="lcb-item">
                        <span class="lcb-label">Email</span>
                        <span class="lcb-val"><a href="mailto:TUAEMAIL@esempio.it">TUAEMAIL@esempio.it</a></span>
                    </div>
                    <div class="lcb-item">
                        <span class="lcb-label">Indirizzo</span>
                        <span class="lcb-val">C.so Garibaldi, snc, Fasano (BR)</span>
                    </div>
                    <div class="lcb-item">
                        <span class="lcb-label">P.IVA / C.F.</span>
                        <span class="lcb-val">SPNPDV07H06F376I</span>
                    </div>
                </div>
            </section>

            
            <section class="legal-section reveal" id="dati-raccolti">
                <span class="legal-section__num">02</span>
                <h2 class="legal-section__title">Dati raccolti</h2>
                <p>
                    Il Sito raccoglie dati personali in due modalità principali:
                    dati forniti volontariamente dall'utente e dati raccolti
                    automaticamente durante la navigazione.
                </p>
                <p><strong>Dati forniti volontariamente</strong></p>
                <ul class="legal-list">
                    <li>Nome e cognome</li>
                    <li>Indirizzo email</li>
                    <li>Nome dell'azienda (facoltativo)</li>
                    <li>Contenuto del messaggio inviato tramite il modulo di contatto</li>
                    <li>Fascia di budget selezionata</li>
                </ul>
                <p><strong>Dati raccolti automaticamente</strong></p>
                <ul class="legal-list">
                    <li>Indirizzo IP (anonimizzato)</li>
                    <li>Tipo di browser e sistema operativo</li>
                    <li>Pagine visitate e tempo di permanenza</li>
                    <li>Sorgente di traffico (URL di provenienza)</li>
                </ul>
                <div class="legal-highlight">
                    <p>
                        <strong>Nota:</strong> Non raccogliamo categorie particolari di dati
                        (dati sensibili, sanitari, biometrici) né dati di persone
                        di età inferiore ai 16 anni.
                    </p>
                </div>
            </section>

            
            <section class="legal-section reveal" id="finalita">
                <span class="legal-section__num">03</span>
                <h2 class="legal-section__title">Finalità e base giuridica</h2>
                <p>
                    I dati sono trattati per le seguenti finalità, ciascuna con
                    la propria base giuridica ai sensi dell'art. 6 GDPR:
                </p>
                <ul class="legal-list">
                    <li>
                        <strong>Gestione delle richieste di contatto</strong> —
                        base giuridica: esecuzione di misure precontrattuali (art. 6.1.b)
                    </li>
                    <li>
                        <strong>Analisi statistica del traffico</strong> —
                        base giuridica: legittimo interesse (art. 6.1.f), con dati aggregati e anonimi
                    </li>
                    <li>
                        <strong>Sicurezza del Sito</strong> —
                        base giuridica: legittimo interesse (art. 6.1.f)
                    </li>
                    <li>
                        <strong>Adempimenti di legge</strong> —
                        base giuridica: obbligo legale (art. 6.1.c)
                    </li>
                </ul>
                <p>
                    Non utilizziamo i tuoi dati per attività di marketing diretto
                    senza previo consenso esplicito.
                </p>
            </section>

            
            <section class="legal-section reveal" id="conservazione">
                <span class="legal-section__num">04</span>
                <h2 class="legal-section__title">Conservazione dei dati</h2>
                <p>
                    I dati personali sono conservati per il tempo strettamente
                    necessario al raggiungimento delle finalità per cui sono stati
                    raccolti, nel rispetto del principio di minimizzazione.
                </p>
                <ul class="legal-list">
                    <li>
                        <strong>Dati del modulo di contatto:</strong> conservati
                        per 24 mesi dalla ricezione, salvo necessità di conservazione
                        per rapporti contrattuali in corso
                    </li>
                    <li>
                        <strong>Log di navigazione:</strong> conservati per un
                        massimo di 12 mesi in forma aggregata e anonimizzata
                    </li>
                    <li>
                        <strong>Dati di fatturazione:</strong> conservati per
                        10 anni in ottemperanza agli obblighi fiscali
                    </li>
                </ul>
                <p>
                    Trascorsi i termini, i dati vengono cancellati o resi
                    definitivamente anonimi.
                </p>
            </section>

            
            <section class="legal-section reveal" id="condivisione">
                <span class="legal-section__num">05</span>
                <h2 class="legal-section__title">Condivisione dei dati</h2>
                <p>
                    I tuoi dati personali non vengono venduti né ceduti a terzi
                    per finalità commerciali. Possono tuttavia essere comunicati a:
                </p>
                <ul class="legal-list">
                    <li>
                        <strong>Cloudflare, Inc.</strong> — fornitore di servizi
                        di hosting e CDN, con sede negli Stati Uniti. Il trasferimento
                        avviene nel rispetto delle garanzie previste dal GDPR
                        (Decisione di adeguatezza / Clausole Contrattuali Standard)
                    </li>
                    <li>
                        <strong>Google LLC</strong> — se attivo Google Analytics,
                        con anonimizzazione IP e senza funzioni di remarketing.
                        Il trasferimento avviene con garanzie adeguate
                    </li>
                    <li>
                        <strong>Autorità competenti</strong> — ove richiesto da
                        obblighi di legge o ordini dell'autorità giudiziaria
                    </li>
                </ul>
                <div class="legal-highlight">
                    <p>
                        Tutti i fornitori sono nominati Responsabili del trattamento
                        ai sensi dell'art. 28 GDPR e trattano i dati esclusivamente
                        secondo le nostre istruzioni.
                    </p>
                </div>
            </section>

            
            <section class="legal-section reveal" id="diritti">
                <span class="legal-section__num">06</span>
                <h2 class="legal-section__title">I tuoi diritti</h2>
                <p>
                    In qualità di interessato, hai il diritto di:
                </p>
                <ul class="legal-list">
                    <li><strong>Accesso</strong> — conoscere quali dati trattiamo e ottenerne copia (art. 15)</li>
                    <li><strong>Rettifica</strong> — correggere dati inesatti o incompleti (art. 16)</li>
                    <li><strong>Cancellazione</strong> — ottenere la cancellazione dei tuoi dati ("diritto all'oblio", art. 17)</li>
                    <li><strong>Limitazione</strong> — limitare il trattamento in determinati casi (art. 18)</li>
                    <li><strong>Portabilità</strong> — ricevere i tuoi dati in formato strutturato (art. 20)</li>
                    <li><strong>Opposizione</strong> — opporti al trattamento basato su legittimo interesse (art. 21)</li>
                    <li><strong>Revoca del consenso</strong> — in qualsiasi momento, senza pregiudizio per il trattamento precedente</li>
                </ul>
                <p>
                    Per esercitare i tuoi diritti, scrivi a
                    <a href="mailto:TUAEMAIL@esempio.it">TUAEMAIL@esempio.it</a>.
                    Risponderemo entro 30 giorni. Hai inoltre il diritto di
                    proporre reclamo al <strong>Garante per la Protezione dei
                    Dati Personali</strong> (<a href="https://www.garanteprivacy.it" target="_blank" rel="noopener">garanteprivacy.it</a>).
                </p>
            </section>

            
            <section class="legal-section reveal" id="minori">
                <span class="legal-section__num">07</span>
                <h2 class="legal-section__title">Minori</h2>
                <p>
                    Il Sito non è destinato a persone di età inferiore ai 16 anni.
                    Non raccogliamo consapevolmente dati personali di minori.
                    Se sei genitore o tutore e ritieni che tuo figlio ci abbia
                    fornito dati personali, contattaci immediatamente: provvederemo
                    alla cancellazione.
                </p>
            </section>

            
            <section class="legal-section reveal" id="modifiche">
                <span class="legal-section__num">08</span>
                <h2 class="legal-section__title">Modifiche alla Privacy Policy</h2>
                <p>
                    Ci riserviamo il diritto di aggiornare la presente Privacy Policy
                    in qualsiasi momento, ad esempio in caso di modifiche normative
                    o cambiamenti nei servizi offerti. La versione aggiornata sarà
                    sempre disponibile a questo indirizzo.
                </p>
                <p>
                    In caso di modifiche sostanziali, ne daremo comunicazione
                    tramite avviso in evidenza sul Sito o, se disponibile,
                    via email.
                </p>
            </section>

            
            <section class="legal-section reveal" id="contatti-privacy">
                <span class="legal-section__num">09</span>
                <h2 class="legal-section__title">Contatti</h2>
                <p>
                    Per qualsiasi domanda relativa al trattamento dei tuoi dati
                    personali o per esercitare i tuoi diritti, puoi contattarci:
                </p>
                <div class="legal-contact-box">
                    <div class="lcb-item">
                        <span class="lcb-label">Email</span>
                        <span class="lcb-val"><a href="mailto:TUAEMAIL@esempio.it">TUAEMAIL@esempio.it</a></span>
                    </div>
                    <div class="lcb-item">
                        <span class="lcb-label">Modulo di contatto</span>
                        <span class="lcb-val"><a href="/contattami">Vai alla pagina contatti →</a></span>
                    </div>
                </div>
            </section>

        </article>
    </div>

    
    <div class="legal-update-strip">
        <div class="legal-update-strip__inner">
            <p class="update-text">
                Leggi anche la nostra
                <strong>Cookie Policy</strong> per capire come utilizziamo i cookie.
            </p>
            <a href="/cookie-policy" class="update-link">
                Vai alla Cookie Policy
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </div>
    </div>

    
    <footer class="main-footer">
        <div class="footer-logo">
            <a href="/">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="footer-logo-img"/>
            </a>
        </div>
        <nav class="footer-nav">
            <a href="/chi-sono">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
            <a href="/processo">PROCESSO</a>
            <a href="/contattami">CONTATTAMI</a>
            <a href="#" class="nav-active">PRIVACY</a>
            <a href="/cookie-policy">COOKIE</a>
        </nav>
        <div class="footer-copyright">
            <p>© 2026 <a href="https://www.instagram.com/_davstudios/" style="color:var(--ink);text-decoration:none">_davstudios</a> — Tutti i diritti riservati</p>
        </div>
    </footer>

    <script>import '../../scripts/global.js'; '../../scripts/legal.js'</script>

</body>
</html>