---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="google-site-verification" content="qznibews_4hVCFJGDhXEtbw1633_Mk03iblVvyLUqhM"/>
    <meta property="article:modified_time" content="2026-03-10T08:40:00+01:00" />
    <meta property="article:published_time" content="2026-03-10T08:45:00+01:00" />

    <!-- SEO primari -->
    <title>Design & Sviluppo Web | _davstudios</title>
    <meta name="description" content="Meno rumore, più impatto. _davstudios progetta identità digitali, siti web e brand per chi vuole distinguersi.">
    <meta name="author" content="David Spano">
    <meta name="robots" content="index, follow">
    <meta name="language" content="it">
    <link rel="canonical" href="https://davstudios.it/">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://davstudios.it/">
    <meta property="og:title" content="Design & Sviluppo Web | _davstudios">
    <meta property="og:description" content="Meno rumore, più impatto. _davstudios progetta identità digitali, siti web e brand per chi vuole distinguersi.">
    <meta property="og:image" content="https://davstudios.it/assets/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="_davstudios">
    <meta property="og:locale" content="it_IT">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Design & Sviluppo Web | _davstudios">
    <meta name="twitter:description" content="Meno rumore, più impatto. _davstudios progetta identità digitali, siti web e brand per chi vuole distinguersi.">
    <meta name="twitter:image" content="https://davstudios.it/assets/og-image.jpg">

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="theme-color" content="#0071E3">

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,300&display=swap" rel="stylesheet">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "_davstudios",
  "url": "https://davstudios.it",
  "logo": "https://davstudios.it/assets/_davstudios.svg",
  "image": "https://davstudios.it/assets/og-image.jpg",
  "description": "Meno rumore, più impatto. _davstudios progetta identità digitali, siti web e brand per chi vuole distinguersi.",
  "founder": { "@type": "Person", "name": "David Spano" },
  "address": { "@type": "PostalAddress", "addressLocality": "Brindisi", "addressRegion": "Puglia", "addressCountry": "IT" },
  "geo": { "@type": "GeoCoordinates", "latitude": 40.8364003, "longitude": 17.3635936 },
  "email": "info@davstudios.it",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "09:00", "closes": "18:00"
  },
  "contactPoint": { "@type": "ContactPoint", "email": "info@davstudios.it", "contactType": "customer service" },
  "sameAs": [
    "https://www.instagram.com/_davstudios",
    "https://www.facebook.com/the.davstudios"
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "_davstudios",
  "url": "https://davstudios.it",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://davstudios.it/?s={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Cosa fa _davstudios?",
      "acceptedAnswer": { "@type": "Answer", "text": "_davstudios progetta identità digitali, siti web e brand per chi vuole distinguersi nel mercato digitale." }
    },
    {
      "@type": "Question",
      "name": "Con chi lavora _davstudios?",
      "acceptedAnswer": { "@type": "Answer", "text": "Lavoro con startup, piccole imprese e professionisti che vogliono una presenza digitale forte e distintiva." }
    },
    {
      "@type": "Question",
      "name": "Dove ha sede _davstudios?",
      "acceptedAnswer": { "@type": "Answer", "text": "_davstudios ha sede in provincia di Brindisi, Puglia, Italia, e lavora con clienti da tutta Italia." }
    },
    {
      "@type": "Question",
      "name": "Quanto costa un sito web con _davstudios?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ogni progetto è su misura. Contattami per un preventivo gratuito personalizzato." }
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://davstudios.it/" }
  ]
}
</script>
</head>
<body>

        
    <nav class="navbar">
        <div class="nav-section nav-left">
            <a href="/chi-sono">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
        </div>
        <div class="nav-logo">
            <a href="#">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="nav-logo-img"/>
            </a>
        </div>
        <div class="nav-section nav-right">
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
    </nav>
    <div class="nav-drawer" id="nav-drawer">
        <div class="nav-drawer__inner">
            <a href="/chi-sono">CHI SONO</a>
            <a href="/progetti">PROGETTI</a>
            <a href="/processo">PROCESSO</a>
            <a href="/contattami" class="btn-contattami">CONTATTAMI</a>
        </div>
    </div>
    <div class="nav-overlay" id="nav-overlay"></div>

    
    <section class="hero-container">
        <div class="hero-header">
            <h2 class="main-title">_davstudios</h2>
            <p class="subtitle">Meno rumore, più impatto. Progettiamo il futuro del tuo brand.</p>
        </div>

        <div class="hero-content">

            
            <div class="content-block reveal">
                <p>
                    In un web affollato, <b>_davstudios</b> aiuta il tuo <b>brand</b>
                    a <b>distinguersi</b>. Superiamo le soluzioni standard con un
                    <b>design audace</b> e una <b>tecnologia d'avanguardia</b>,
                    creando <b>ecosistemi digitali dinamici</b> dall'impatto immediato.
                    Uniamo <b>direzione creativa</b> e uno <b>sviluppo web solido e scalabile</b>
                    per affrontare ogni sfida. Non offriamo semplici servizi, ma
                    <b>identità digitali forti</b> per chi vuole <b>innovare</b>
                    e lasciare il segno nel <b>panorama digitale</b> odierno.
                </p>
            </div>

            
            <div class="content-block svg-block reveal delay-1">
				<img src="/assets/logo.svg" alt="_davstudioslogo" style="max-width: 80%; height: auto;" />
			</div>

        </div>
    </section>

    
    <section class="process-section">
        <div class="process-header reveal">
            <h2>Il Processo</h2>
            <p>Come lavoro, passo dopo passo</p>
        </div>

        <div class="steps-container reveal delay-1">
            <div class="step-item">
                <div class="circle">1</div>
                <span class="step-label">Ascolto</span>
            </div>
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="step-item">
                <div class="circle">2</div>
                <span class="step-label">Ricerca</span>
            </div>
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="step-item">
                <div class="circle">3</div>
                <span class="step-label">Struttura</span>
            </div>
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="step-item">
                <div class="circle">4</div>
                <span class="step-label">Design</span>
            </div>
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="step-item">
                <div class="circle">5</div>
                <span class="step-label">Revisione</span>
            </div>
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="step-item">
                <div class="circle">6</div>
                <span class="step-label">Lancio</span>
            </div>
        </div>

        
        <div class="main-text-block reveal delay-2">
            Ogni successo è frutto di un <b>metodo di lavoro</b>
            rigoroso che trasforma le tue idee in un <b>prodotto digitale</b>
            d'eccellenza. Il percorso parte dall'<b>ascolto</b> della tua
            visione per definire una <b>strategia</b> mirata. Proseguiamo
            con il <b>design</b> funzionale e lo <b>sviluppo</b> tecnico fluido,
            seguiti da una <b>revisione</b> minuziosa per un'<b>esperienza utente</b>
            impeccabile. Infine, il <b>lancio</b> posiziona la tua nuova identità
            online con precisione e impatto sul mercato.
        </div>
    </section>

    
    <section class="gallery-section">
        <div class="gallery-header reveal">
            <h2>Progetti</h2>
            <p>Una selezione dei lavori recenti</p>
        </div>

        <div class="images-container">
            
            <div class="image-box reveal">
                <div class="img-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="3"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <path d="M21 15l-5-5L5 21"/>
                    </svg>
                    <span>Immagine 1</span>
                </div>
            </div>

            
            <div class="image-box reveal delay-1">
                <div class="img-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="3"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <path d="M21 15l-5-5L5 21"/>
                    </svg>
                    <span>Immagine 2</span>
                </div>
            </div>
        </div>

        <div class="button-wrapper reveal">
            <a href="/progetti" class="btn-oval">Guarda tutti i progetti</a>
        </div>
    </section>

    
    <section class="action-section">
        <div class="action-header reveal">
            <h2>Contattami</h2>
            <p>Scegli il canale che preferisci</p>
        </div>

        
        <div class="buttons-grid reveal delay-1">

            <a href="https://wa.me/393934740930" class="btn-rect btn-wa" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.116 1.524 5.847L0 24l6.341-1.498A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.6a9.554 9.554 0 01-4.894-1.345l-.35-.21-3.633.858.902-3.536-.228-.363A9.555 9.555 0 012.4 12C2.4 6.698 6.698 2.4 12 2.4S21.6 6.698 21.6 12 17.302 21.6 12 21.6z"/>
                </svg>
                WA Business
            </a>

            <a href="https://instagram.com/_davstudios" class="btn-rect btn-ig" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <circle cx="12" cy="12" r="4"/>
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
                Instagram
            </a>

            <a href="https://facebook.com/the.davstudios" class="btn-rect btn-fb" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
            </a>

            <a href="mailto:TUAEMAIL@esempio.com" class="btn-rect btn-email">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                Email
            </a>

        </div>

        
        <div class="footer-text-block reveal delay-2">
            Hai un’idea da sviluppare o un <b>brand</b> da far crescere?
            Non esitare a scrivermi per richiedere un <b>preventivo personalizzato</b>
            o per ricevere maggiori informazioni sui miei servizi di <b>design e sviluppo</b>.
            In <b>_davstudios</b> crediamo che la qualità nasca dal dialogo costante:
            analizzeremo le tue necessità per costruire una <b>soluzione tecnica</b>
            impeccabile e un'estetica capace di <b>distinguersi</b> nel mercato attuale.
            Scegli la piattaforma che ti è più comoda e mettiamoci subito al lavoro.
        </div>
    </section>

        
    <footer class="main-footer">
        <div class="footer-logo">
            <a href="#">
                <img src="/assets/_davstudios.svg" alt="_davstudios" class="footer-logo-img"/>
            </a>
        </div>
        <nav class="footer-nav">
            <a href="/chi-sono" >CHI SONO</a>
            <a href="/progetti" >PROGETTI</a>
            <a href="/processo" >PROCESSO</a>
            <a href="/contattami" >CONTATTAMI</a>
            <a href="/privacy-policy" >PRIVACY</a>
            <a href="/cookie-policy" >COOKIE</a>
        </nav>
        <div class="footer-copyright">
            <p>© 2026 <a href="https://www.instagram.com/_davstudios/" style="color:var(--ink);text-decoration:none">_davstudios</a> — Tutti i diritti riservati</p>
        </div>
    </footer>

    
    <script>
        import '../scripts/global.js';
    </script>

</body>
</html>